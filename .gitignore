dist/
build/
.eggs/
*.egg
.mypy_cache/
.ruff_cache/

# ── Environment ──────────────────────────────────────
.env
.env.local
.env.*.local
venv/
.venv/

# ── IDE ──────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ── Docker ───────────────────────────────────────────
docker-compose.override.yml

