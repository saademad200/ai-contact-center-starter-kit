# AI Contact Center — .gitignore

# ── Python ────────────────────────────────────────────
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/
.eggs/
*.egg
.mypy_cache/
.ruff_cache/

# ── Environment ──────────────────────────────────────
.env
.env.local
.env.*.local
venv/
.venv/

# ── IDE ──────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ── Docker ───────────────────────────────────────────
docker-compose.override.yml

# ── Terraform ────────────────────────────────────────
*.tfstate
*.tfstate.*
.terraform/
.terraform.lock.hcl
*.tfplan
crash.log

# ── Knowledge Base (raw downloads) ───────────────────
knowledge_base/raw_docs/

# ── OS ───────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Coverage ─────────────────────────────────────────
htmlcov/
test-results/
playwright-report/
.coverage
coverage.xml

# ── Secrets ──────────────────────────────────────────
.secrets.baseline
node_modules/
*.zip

# ── Local Claude context (personal, not for repo) ────
CLAUDE.LOCAL.MD

# ── Personal research / autoresearch log (not for public repo) ───
RESEARCH.md
