# ==============================================================================
# Alfalah Investments AI Contact Centre
# Environment Variables
# ==============================================================================
# COPY THIS FILE TO .env AND FILL IN THE VALUES

# ── App Environment ───────────────────────────────────────────────────────────
ENVIRONMENT=development
# Secret key for signing JWT tokens (generate using `openssl rand -hex 32`)
JWT_SECRET_KEY=replace-with-secure-random-string

# ── LLM & Observability ───────────────────────────────────────────────────────
# OpenAI API Key for GPT-4o-mini and Fine-Tuning
OPENAI_API_KEY=sk-proj-...

# Langfuse Configuration
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_HOST=https://us.cloud.langfuse.com

# ── AWS Configuration ─────────────────────────────────────────────────────────
AWS_REGION=us-east-1

# S3 bucket where raw data (e.g., prospectuses) and cleaned jsonl data is stored
S3_BUCKET_NAME=alfalah-ai-data-staging

# Endpoint for DynamoDB (leave blank for production to use real AWS DynamoDB, set to local for dev)
DYNAMODB_ENDPOINT_URL=http://localhost:8001
