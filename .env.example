# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# AI Contact Centre — Environment Variables
# See PROJECT_PLAN.md §15 for full documentation
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# ── App ──────────────────────────────────────────────────────
ENVIRONMENT=development
SECRET_KEY=replace-with-openssl-rand-hex-32
CORS_ORIGINS=http://localhost:3000

# ── AWS ──────────────────────────────────────────────────────
AWS_REGION=us-east-1
S3_BUCKET_NAME=acc-documents-dev

# ── DynamoDB ─────────────────────────────────────────────────
DYNAMODB_ENDPOINT_URL=http://localhost:8001
TABLE_PREFIX=acc-development

# ── ChromaDB ─────────────────────────────────────────────────
CHROMA_HOST=chromadb
CHROMA_PORT=8000
CHROMA_COLLECTION=almeezan_knowledge

# ── LLM (Groq — free tier) ──────────────────────────────────
GROQ_API_KEY=gsk_xxx
GROQ_MODEL=llama-3.1-70b-versatile

# ── Embeddings ───────────────────────────────────────────────
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# ── Email (SES — ticket + deploy notifications) ─────────────
SES_SENDER_EMAIL=support@almeezan.com
SES_SUPPORT_TEAM_EMAIL=support-team@almeezan.com

# ── Admin Auth ───────────────────────────────────────────────
ADMIN_EMAIL=admin@almeezan.com
ADMIN_PASSWORD=change-me-now
JWT_SECRET_KEY=replace-with-openssl-rand-hex-32
JWT_EXPIRE_MINUTES=480
